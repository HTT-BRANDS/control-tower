{
  "description": "Trigger a manual data synchronization job",
  "example_request": {
    "sync_types": ["costs", "compliance", "resources", "identity"],
    "tenant_ids": ["12345678-1234-1234-1234-123456789012"],
    "force_full_sync": false,
    "priority": "normal",
    "options": {
      "incremental_days": 7,
      "parallel_tenants": 3,
      "timeout_minutes": 60,
      "retry_failed": true,
      "notify_on_completion": true
    }
  },
  "field_descriptions": {
    "sync_types": "Types of data to synchronize (array)",
    "tenant_ids": "Specific tenants to sync (empty = all tenants)",
