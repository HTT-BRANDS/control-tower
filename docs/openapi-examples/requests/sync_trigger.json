    "priority": "Job priority: low, normal, high, critical",
    "options": "Additional sync options"
  },
  "sync_types_enum": [
    "costs",
    "compliance",
    "resources",
    "identity",
    "budgets",
    "riverside",
    "dmarc"
  ],
  "priority_enum": ["low", "normal", "high", "critical"],
  "minimal_request": {
    "sync_types": ["costs"]
  },
  "full_request": {
    "sync_types": ["costs", "compliance", "resources", "identity", "riverside"],
    "tenant_ids": [],
    "force_full_sync": true,
    "priority": "high",
    "options": {
      "incremental_days": 30,
      "parallel_tenants": 5,
      "timeout_minutes": 120,
      "retry_failed": true,
      "notify_on_completion": true
    }
