{
  "description": "OAuth2 Authorization Code Flow for Azure AD Authentication",
  "flow": "authorizationCode",
  "authorizationUrl": "https://login.microsoftonline.com/common/oauth2/v2.0/authorize",
  "tokenUrl": "https://login.microsoftonline.com/common/oauth2/v2.0/token",
  "refreshUrl": "https://login.microsoftonline.com/common/oauth2/v2.0/token",
  "scopes": {
    "openid": "Authenticate user identity",
    "profile": "Access user profile information",
    "email": "Access user email address",
    "User.Read": "Read user profile from Microsoft Graph"
  },
  "example_request": {
    "client_id": "your-azure-ad-client-id",
    "response_type": "code",
    "redirect_uri": "https://your-app.azurewebsites.net/auth/callback",
    "scope": "openid profile email User.Read",
    "state": "random-state-value-for-csrf-protection",
    "prompt": "select_account"
  },
  "example_token_response": {
    "token_type": "Bearer",
    "scope": "openid profile email User.Read",
    "expires_in": 3600,
    "ext_expires_in": 3600,
    "access_token": "eyJ0eXAiOiJKV1QiLCJhbGciOiJSUzI1NiIsIng1dCI6...",
    "refresh_token": "0.ASAA...",
    "id_token": "eyJ0eXAiOiJKV1QiLCJhbGciOiJSUzI1NiIsIng1dCI6..."
  },
  "example_error_response": {
    "error": "invalid_grant",
    "error_description": "AADSTS70000: The provided value for the 'code' parameter is not valid.",
    "error_codes": [70000],
    "timestamp": "2026-01-15T10:30:00Z",
    "correlation_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890"
  }
}
