{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.41.2.15936",
      "templateHash": "10194860976893446029"
    }
  },
  "parameters": {
    "uamiName": {
      "type": "string",
      "defaultValue": "mi-control-tower",
      "metadata": {
        "description": "Name of the User-Assigned Managed Identity"
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Azure region for resources"
      }
    },
    "federatedIdentityCredentialName": {
      "type": "string",
      "defaultValue": "github-actions-federation",
      "metadata": {
        "description": "Name for the Federated Identity Credential"
      }
    },
    "githubOrganization": {
      "type": "string",
      "metadata": {
        "description": "GitHub organization name"
      }
    },
    "githubRepository": {
      "type": "string",
      "metadata": {
        "description": "GitHub repository name"
      }
    },
    "githubRef": {
      "type": "string",
      "defaultValue": "refs/heads/main",
      "allowedValues": [
        "refs/heads/main",
        "refs/heads/staging",
        "environment:production",
        "environment:staging"
      ],
      "metadata": {
        "description": "GitHub branch or environment for OIDC federation"
      }
    },
    "keyVaultName": {
      "type": "string",
      "metadata": {
        "description": "Name of the Key Vault for role assignment"
      }
    },
    "additionalRoleAssignments": {
      "type": "array",
      "defaultValue": [],
      "metadata": {
        "description": "Array of additional role assignments for the UAMI"
      }
    },
    "tags": {
      "type": "object",
      "defaultValue": {
        "Environment": "production",
        "Project": "control-tower",
        "Phase": "C",
        "ManagedBy": "bicep"
      },
      "metadata": {
        "description": "Tags to apply to resources"
      }
    },
    "enableDiagnostics": {
      "type": "bool",
      "defaultValue": true,
      "metadata": {
        "description": "Enable diagnostic settings"
      }
    },
    "logAnalyticsWorkspaceId": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Log Analytics workspace ID for diagnostics"
      }
    }
  },
  "resources": [
    {
      "type": "Microsoft.ManagedIdentity/userAssignedIdentities",
      "apiVersion": "2023-01-31",
      "name": "[parameters('uamiName')]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]"
    },
    {
      "type": "Microsoft.ManagedIdentity/userAssignedIdentities/federatedIdentityCredentials",
      "apiVersion": "2023-01-31",
      "name": "[format('{0}/{1}', parameters('uamiName'), parameters('federatedIdentityCredentialName'))]",
      "properties": {
        "issuer": "https://token.actions.githubusercontent.com",
        "subject": "[format('repo:{0}/{1}:{2}', parameters('githubOrganization'), parameters('githubRepository'), parameters('githubRef'))]",
        "audiences": [
          "api://AzureADTokenExchange"
        ]
      },
      "dependsOn": [
        "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', parameters('uamiName'))]"
      ]
    },
    {
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "scope": "[resourceId('Microsoft.KeyVault/vaults', parameters('keyVaultName'))]",
      "name": "[guid(resourceId('Microsoft.KeyVault/vaults', parameters('keyVaultName')), resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', parameters('uamiName')), '4633458b-17de-408a-b874-0445caeb07de')]",
      "properties": {
        "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', '4633458b-17de-408a-b874-0445caeb07de')]",
        "principalId": "[reference(resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', parameters('uamiName')), '2023-01-31').principalId]",
        "principalType": "ServicePrincipal",
        "description": "Allow UAMI to read secrets from Key Vault for Phase C zero-secrets auth"
      },
      "dependsOn": [
        "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', parameters('uamiName'))]"
      ]
    },
    {
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "scope": "[resourceId('Microsoft.KeyVault/vaults', parameters('keyVaultName'))]",
      "name": "[guid(resourceId('Microsoft.KeyVault/vaults', parameters('keyVaultName')), resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', parameters('uamiName')), '21090545-7ca7-4776-b22c-e363652d74d2')]",
      "properties": {
        "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', '21090545-7ca7-4776-b22c-e363652d74d2')]",
        "principalId": "[reference(resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', parameters('uamiName')), '2023-01-31').principalId]",
        "principalType": "ServicePrincipal",
        "description": "Allow UAMI to read Key Vault metadata"
      },
      "dependsOn": [
        "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', parameters('uamiName'))]"
      ]
    },
    {
      "copy": {
        "name": "additionalRoles",
        "count": "[length(parameters('additionalRoleAssignments'))]"
      },
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "name": "[guid(parameters('additionalRoleAssignments')[copyIndex()].scopeResourceId, resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', parameters('uamiName')), parameters('additionalRoleAssignments')[copyIndex()].roleDefinitionId)]",
      "properties": {
        "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', parameters('additionalRoleAssignments')[copyIndex()].roleDefinitionId)]",
        "principalId": "[reference(resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', parameters('uamiName')), '2023-01-31').principalId]",
        "principalType": "ServicePrincipal",
        "description": "[parameters('additionalRoleAssignments')[copyIndex()].description]"
      },
      "dependsOn": [
        "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', parameters('uamiName'))]"
      ]
    },
    {
      "condition": "[and(parameters('enableDiagnostics'), not(empty(parameters('logAnalyticsWorkspaceId'))))]",
      "type": "Microsoft.Insights/diagnosticSettings",
      "apiVersion": "2021-05-01-preview",
      "scope": "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', parameters('uamiName'))]",
      "name": "[format('{0}-diagnostics', parameters('uamiName'))]",
      "properties": {
        "workspaceId": "[parameters('logAnalyticsWorkspaceId')]",
        "logs": [
          {
            "category": "AuditEvent",
            "enabled": true
          }
        ],
        "metrics": [
          {
            "category": "AllMetrics",
            "enabled": true
          }
        ]
      },
      "dependsOn": [
        "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', parameters('uamiName'))]"
      ]
    }
  ],
  "outputs": {
    "uamiClientId": {
      "type": "string",
      "metadata": {
        "description": "Client ID of the User-Assigned Managed Identity"
      },
      "value": "[reference(resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', parameters('uamiName')), '2023-01-31').clientId]"
    },
    "uamiPrincipalId": {
      "type": "string",
      "metadata": {
        "description": "Principal ID (Object ID) of the UAMI"
      },
      "value": "[reference(resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', parameters('uamiName')), '2023-01-31').principalId]"
    },
    "uamiResourceId": {
      "type": "string",
      "metadata": {
        "description": "Resource ID of the UAMI"
      },
      "value": "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', parameters('uamiName'))]"
    },
    "uamiName": {
      "type": "string",
      "metadata": {
        "description": "Name of the UAMI"
      },
      "value": "[parameters('uamiName')]"
    },
    "uamiTenantId": {
      "type": "string",
      "metadata": {
        "description": "Tenant ID of the UAMI"
      },
      "value": "[reference(resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', parameters('uamiName')), '2023-01-31').tenantId]"
    },
    "federatedIdentityCredentialName": {
      "type": "string",
      "metadata": {
        "description": "Federated Identity Credential name"
      },
      "value": "[parameters('federatedIdentityCredentialName')]"
    },
    "federatedIdentityCredentialIssuer": {
      "type": "string",
      "metadata": {
        "description": "Federated Identity Credential issuer"
      },
      "value": "[reference(resourceId('Microsoft.ManagedIdentity/userAssignedIdentities/federatedIdentityCredentials', parameters('uamiName'), parameters('federatedIdentityCredentialName')), '2023-01-31').issuer]"
    },
    "federatedIdentityCredentialSubject": {
      "type": "string",
      "metadata": {
        "description": "Federated Identity Credential subject"
      },
      "value": "[reference(resourceId('Microsoft.ManagedIdentity/userAssignedIdentities/federatedIdentityCredentials', parameters('uamiName'), parameters('federatedIdentityCredentialName')), '2023-01-31').subject]"
    },
    "appServiceIdentityConfig": {
      "type": "object",
      "metadata": {
        "description": "Full configuration for App Service integration"
      },
      "value": {
        "type": "UserAssigned",
        "userAssignedIdentities": {
          "[format('{0}', resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', parameters('uamiName')))]": {}
        }
      }
    },
    "appEnvironmentVariables": {
      "type": "object",
      "metadata": {
        "description": "Environment variables for application configuration"
      },
      "value": {
        "UAMI_CLIENT_ID": "[reference(resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', parameters('uamiName')), '2023-01-31').clientId]",
        "UAMI_PRINCIPAL_ID": "[reference(resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', parameters('uamiName')), '2023-01-31').principalId]",
