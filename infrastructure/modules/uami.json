        "AZURE_TENANT_ID": "[reference(resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', parameters('uamiName')), '2023-01-31').tenantId]",
        "AZURE_SUBSCRIPTION_ID": "[subscription().subscriptionId]"
      }
    },
    "phaseCSummary": {
      "type": "object",
      "metadata": {
        "description": "Summary of Phase C configuration"
      },
      "value": {
        "uami": {
          "name": "[parameters('uamiName')]",
          "clientId": "[reference(resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', parameters('uamiName')), '2023-01-31').clientId]",
          "principalId": "[reference(resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', parameters('uamiName')), '2023-01-31').principalId]"
        },
        "federation": {
          "credentialName": "[parameters('federatedIdentityCredentialName')]",
          "issuer": "[reference(resourceId('Microsoft.ManagedIdentity/userAssignedIdentities/federatedIdentityCredentials', parameters('uamiName'), parameters('federatedIdentityCredentialName')), '2023-01-31').issuer]",
          "subject": "[reference(resourceId('Microsoft.ManagedIdentity/userAssignedIdentities/federatedIdentityCredentials', parameters('uamiName'), parameters('federatedIdentityCredentialName')), '2023-01-31').subject]"
        },
        "roleAssignments": [
          {
            "role": "Key Vault Secrets User",
            "scope": "[parameters('keyVaultName')]"
          },
          {
            "role": "Key Vault Reader",
            "scope": "[parameters('keyVaultName')]"
          }
        ]
      }
    }
  }
