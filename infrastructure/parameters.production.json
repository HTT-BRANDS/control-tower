{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "environment": {
      "value": "production"
    },
    "location": {
      "value": "eastus"
    },
    "secondaryLocation": {
      "value": "westus2"
    },
    "appServiceSku": {
      "value": "B1"
    },
    "sqlDatabaseSku": {
      "value": "Standard_S0"
    },
    "enableAzureSql": {
      "value": true
    },
    "enableAppInsights": {
      "value": true
    },
    "enableKeyVault": {
      "value": true
    },
    "enableVNetIntegration": {
      "value": false
    },
    "logRetentionDays": {
      "value": 90
    },
    "containerImage": {
      "value": "acrgovprod.azurecr.io/azure-governance-platform:latest"
    },
    "useContainerDeployment": {
      "value": true
    },
    "acrName": {
      "value": "acrgovprod"
    },
    "tags": {
      "value": {
        "Application": "Azure Governance Platform",
        "Environment": "production",
        "ManagedBy": "Bicep",
        "CostCenter": "IT-Operations",
        "Owner": "Cloud-Team",
        "Compliance": "Riverside"
      }
    },
    "azureAdTenantId": {
      "value": ""
    },
    "azureAdClientId": {
      "value": ""
    },
    "corsOrigins": {
      "value": "https://app-governance-prod.azurewebsites.net"
    },
    "adminEmails": {
      "value": ""
    },
    "enableRedis": {
      "value": true
    }
  }
}
