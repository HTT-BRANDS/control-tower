# Azure Governance Platform - Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================

# Application mode (set to false in production)
DEBUG=true

# JWT Secret Key (REQUIRED in production - generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
# JWT_SECRET_KEY=

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Server configuration
HOST=0.0.0.0
PORT=8000

# =============================================================================
# DATABASE
# =============================================================================

# SQLite database path (relative to project root)
DATABASE_URL=sqlite:///./data/governance.db

# =============================================================================
# AZURE AUTHENTICATION (Primary Tenant)
# =============================================================================

# Your managing tenant's Azure AD tenant ID
# Typically the HTT tenant (0c0e35dc-188a-4eb3-b8ba-61752154b407)
AZURE_TENANT_ID=0c0e35dc-188a-4eb3-b8ba-61752154b407

# App registration client ID
AZURE_CLIENT_ID=

# App registration client secret (use Key Vault ref in production)
# NOT REQUIRED when USE_OIDC_FEDERATION=true
AZURE_CLIENT_SECRET=

# =============================================================================
# OIDC WORKLOAD IDENTITY FEDERATION (Recommended for Production)
# Replaces AZURE_CLIENT_SECRET — no secrets stored anywhere
# =============================================================================

# Set to true to use OIDC Workload Identity Federation instead of client secrets.
# Requires federated credentials configured on each tenant's app registration.
# Run: ./scripts/setup-federated-creds.sh --help
USE_OIDC_FEDERATION=false

# Client ID of the user-assigned managed identity on the App Service.
# Leave empty if using system-assigned managed identity.
# Found at: Azure Portal → App Service → Identity → User assigned
AZURE_MANAGED_IDENTITY_CLIENT_ID=

# =============================================================================
# AZURE KEY VAULT (Production)
# =============================================================================

# Key Vault URL for storing tenant credentials
# NOT REQUIRED when USE_OIDC_FEDERATION=true
# KEY_VAULT_URL=https://your-keyvault.vault.azure.net/

# =============================================================================
# MANAGED TENANTS
# =============================================================================

# Comma-separated list of tenant IDs to manage
# Leave empty if using Azure Lighthouse
# MANAGED_TENANT_IDS=tenant-id-1,tenant-id-2,tenant-id-3,tenant-id-4

# =============================================================================
# SYNC CONFIGURATION
# =============================================================================

# How often to sync cost data (in hours)
COST_SYNC_INTERVAL_HOURS=24

# How often to sync compliance data (in hours)
COMPLIANCE_SYNC_INTERVAL_HOURS=4

# How often to sync resource inventory (in hours)
RESOURCE_SYNC_INTERVAL_HOURS=1

# How often to sync identity data (in hours)
IDENTITY_SYNC_INTERVAL_HOURS=24

# =============================================================================
# ALERTING
# =============================================================================

# Microsoft Teams webhook URL for alerts
# TEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/...

# Cost anomaly detection threshold (percentage increase to trigger alert)
COST_ANOMALY_THRESHOLD_PERCENT=20.0

# Compliance score drop threshold (percentage drop to trigger alert)
COMPLIANCE_ALERT_THRESHOLD_PERCENT=5.0

# =============================================================================
# CORS (Development only)
# =============================================================================

# Allowed origins for CORS (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# =============================================================================
# RIVERSIDE TENANT CONFIGURATION
# =============================================================================

# Enable Riverside compliance tracking features
RIVERSIDE_COMPLIANCE_ENABLED=true

# Azure Key Vault URL for storing tenant credentials
# Format: https://{vault-name}.vault.azure.net/
# NOT REQUIRED when USE_OIDC_FEDERATION=true
KEY_VAULT_URL=https://riverside-kv.vault.azure.net/

# Riverside Tenant IDs (comma-separated for reference)
RIVERSIDE_TENANT_IDS=0c0e35dc-188a-4eb3-b8ba-61752154b407,b5380912-79ec-452d-a6ca-6d897b19b294,98723287-044b-4bbb-9294-19857d4128a0,3c7d2bf3-b597-4766-b5cb-2b489c2904d6

# HTT (Head-To-Toe) Tenant
RIVERSIDE_HTT_TENANT_ID=0c0e35dc-188a-4eb3-b8ba-61752154b407
RIVERSIDE_HTT_APP_ID=1e3e8417-49f1-4d08-b7be-47045d8a12e9
RIVERSIDE_HTT_SECRET_REF=htt-client-secret

# BCC (Bishops) Tenant
RIVERSIDE_BCC_TENANT_ID=b5380912-79ec-452d-a6ca-6d897b19b294
RIVERSIDE_BCC_APP_ID=4861906b-2079-4335-923f-a55cc0e44d64
RIVERSIDE_BCC_SECRET_REF=bcc-client-secret

# FN (Frenchies) Tenant
RIVERSIDE_FN_TENANT_ID=98723287-044b-4bbb-9294-19857d4128a0
RIVERSIDE_FN_APP_ID=7648d04d-ccc4-43ac-bace-da1b68bf11b4
RIVERSIDE_FN_SECRET_REF=fn-client-secret

# TLL (Lash Lounge) Tenant
RIVERSIDE_TLL_TENANT_ID=3c7d2bf3-b597-4766-b5cb-2b489c2904d6
RIVERSIDE_TLL_APP_ID=52531a02-78fd-44ba-9ab9-b29675767955
RIVERSIDE_TLL_SECRET_REF=tll-client-secret

# DCE (Delta Crown Extensions) Tenant
RIVERSIDE_DCE_TENANT_ID=ce62e17d-2feb-4e67-a115-8ea4af68da30
RIVERSIDE_DCE_APP_ID=79c22a10-3f2d-4e6a-bddc-ee65c9a46cb0
# RIVERSIDE_DCE_SECRET_REF=dce-client-secret  # NOT NEEDED — use OIDC federation

# =============================================================================
# DMARC/DKIM MONITORING SETTINGS
# =============================================================================

# Enable DMARC/DKIM monitoring
DMARC_DKIM_ENABLED=true

# Sync interval in minutes
DMARC_SYNC_INTERVAL_MINUTES=60
DKIM_SYNC_INTERVAL_MINUTES=60

# Alert thresholds (percentage)
DMARC_FAILURE_THRESHOLD_PERCENT=5.0
DKIM_FAILURE_THRESHOLD_PERCENT=5.0

# Data retention in days
DMARC_DATA_RETENTION_DAYS=90

# =============================================================================
# RIVERSIDE COMPLIANCE SETTINGS
# =============================================================================

# Riverside compliance deadline date
RIVERSIDE_DEADLINE_DATE=2026-07-08

# Target MFA coverage percentage
RIVERSIDE_MFA_TARGET=100

# Target maturity score (out of 5.0)
RIVERSIDE_MATURITY_TARGET=3.0

# How often to sync Riverside compliance data (in hours)
RIVERSIDE_SYNC_INTERVAL_HOURS=4

# Financial risk amount in USD (for display purposes)
RIVERSIDE_FINANCIAL_RISK=4000000

# Number of users across all Riverside tenants
RIVERSIDE_TOTAL_USERS=1992

# Number of admin accounts to track
RIVERSIDE_ADMIN_ACCOUNTS=39

# Threat Beta score baseline (if available from Cybeta)
RIVERSIDE_THREAT_BETA_BASELINE=1.0

# Upload directory for compliance evidence files
RIVERSIDE_EVIDENCE_PATH=./data/riverside/evidence

# =============================================================================
# TENANT-SPECIFIC MFA TARGETS (Comma-separated: tenant_id=mfa_target)
# =============================================================================
# Example: HTT=100,BCC=100,FN=100,TLL=100
RIVERSIDE_TENANT_MFA_TARGETS=
