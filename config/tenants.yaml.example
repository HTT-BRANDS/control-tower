# config/tenants.yaml.example — Riverside Tenant Configuration TEMPLATE
#
# Copy this file to config/tenants.yaml and fill in your real Azure AD values:
#   cp config/tenants.yaml.example config/tenants.yaml
#
# config/tenants.yaml is gitignored — real IDs never enter version control.
# This resolves security audit finding LOW-1 (reconnaissance aid).
#
# The UUIDs below are valid-format PLACEHOLDERS — replace with your real values.
#
# Authentication modes:
#   oidc_enabled: true   → OIDC Workload Identity Federation (zero secrets)
#   oidc_enabled: false  → Client secret via Key Vault (key_vault_secret_name required)
#
# Phase B: Multi-tenant App Registration (recommended for 5+ tenants)
#   Instead of 5 separate app registrations (1 per tenant), use a single
#   multi-tenant app in the home tenant (HTT) with signInAudience: AzureADMultipleOrgs.
#
#   Benefits:
#     - Single client secret for all tenants (easier rotation)
#     - One admin consent operation per foreign tenant (one-time)
#     - Simpler configuration management
#
#   Setup:
#     1. Create multi-tenant app in home tenant (HTT)
#     2. Add API permissions (see scripts/setup-multi-tenant-app.sh)
#     3. Grant admin consent in each tenant (BCC, FN, TLL, DCE)
#     4. Set multi_tenant_app_id globally or per-tenant below
#     5. Store single secret in Key Vault as "multi-tenant-client-secret"
#
#   Configuration options:
#     a) Global multi_tenant_app_id (all tenants share the same app):
#        multi_tenant_app_id: "00000000-0000-4000-c000-000000000000"
#
#     b) Per-tenant override (specific tenant uses different app):
#        tenants:
#          HTT:
#            app_id: "per-tenant-app-id"           # Phase A: per-tenant
#            multi_tenant_app_id: "multi-tenant-id" # Phase B: shared app
#
# See docs/runbooks/phase-b-multi-tenant-app.md for detailed setup.
# See docs/AUTH_TRANSITION_ROADMAP.md for migration guidance.

# Phase B: Uncomment and set this for global multi-tenant app mode
# multi_tenant_app_id: "00000000-0000-4000-c000-000000000000"

tenants:
  HTT:
    name: "Head-To-Toe (HTT)"
    code: "HTT"
    tenant_id: "00000000-0000-4000-a000-000000000001"
    # Phase A: Per-tenant app registration (original)
    app_id: "00000000-0000-4000-b000-000000000001"
    # Phase B: Override with multi-tenant app ID (optional, inherits from global if set)
    # multi_tenant_app_id: "00000000-0000-4000-c000-000000000000"
    admin_email: "admin@example-htt.com"
    # Phase A: Per-tenant secret (when oidc_enabled=false and no multi-tenant app)
    key_vault_secret_name: "htt-client-secret"  # pragma: allowlist secret
    # Phase B: Use shared multi-tenant secret instead
    # key_vault_secret_name: "multi-tenant-client-secret"  # pragma: allowlist secret
    domains:
      - "example-htt.com"
    is_active: true
    is_riverside: true
    priority: 1
    oidc_enabled: false

  BCC:
    name: "Bishops (BCC)"
    code: "BCC"
    tenant_id: "00000000-0000-4000-a000-000000000002"
    app_id: "00000000-0000-4000-b000-000000000002"
    admin_email: "admin@example-bcc.com"
    key_vault_secret_name: "bcc-client-secret"  # pragma: allowlist secret
    domains:
      - "example-bcc.com"
    is_active: true
    is_riverside: true
    priority: 2
    oidc_enabled: false

  FN:
    name: "Frenchies (FN)"
    code: "FN"
    tenant_id: "00000000-0000-4000-a000-000000000003"
    app_id: "00000000-0000-4000-b000-000000000003"
    admin_email: "admin@example-fn.com"
    key_vault_secret_name: "fn-client-secret"  # pragma: allowlist secret
    domains:
      - "example-fn.com"
    is_active: true
    is_riverside: true
    priority: 3
    oidc_enabled: false

  TLL:
    name: "Lash Lounge (TLL)"
    code: "TLL"
    tenant_id: "00000000-0000-4000-a000-000000000004"
    app_id: "00000000-0000-4000-b000-000000000004"
    admin_email: "admin@example-tll.com"
    key_vault_secret_name: "tll-client-secret"  # pragma: allowlist secret
    domains:
      - "example-tll.com"
    is_active: true
    is_riverside: true
    priority: 4
    oidc_enabled: false

  DCE:
    name: "Delta Crown Extensions (DCE)"
    code: "DCE"
    tenant_id: "00000000-0000-4000-a000-000000000005"
    app_id: "00000000-0000-4000-b000-000000000005"
    admin_email: "admin@example-dce.com"
    key_vault_secret_name: "dce-client-secret"  # pragma: allowlist secret
    domains:
      - "example-dce.com"
    is_active: true
    is_riverside: true
    priority: 5
    oidc_enabled: false
